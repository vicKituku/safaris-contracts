6550012000001, "b": 139.8196625245579, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 156]}], "orig": "We strive to create a memorable experience that's both comfortable and enriching. We invite you to come, relax, and enjoy everything our hotel has to offer.", "text": "We strive to create a memorable experience that's both comfortable and enriching. We invite you to come, relax, and enjoy everything our hotel has to offer."}, {"self_ref": "#/texts/17", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 2, "bbox": {"l": 200.7466, "t": 134.52924999999993, "r": 274.60052685000005, "b": 121.47646252455787, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 82]}], "orig": "Tha Nickolee Hotel embodies a refined elegance that whispers luxe in every detail.", "text": "Tha Nickolee Hotel embodies a refined elegance that whispers luxe in every detail."}, {"self_ref": "#/texts/18", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 2, "bbox": {"l": 200.7466, "t": 116.18604999999992, "r": 275.1420334, "b": 89.37586252455785, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 211]}], "orig": "This exquisite gem boasts 60 thoughtfully designed rooms and 8 suites, Conferencing, Health & fitness centre and Spa, merging artistry with comfort to create an ambiance that feels both inviting and distinctive.", "text": "This exquisite gem boasts 60 thoughtfully designed rooms and 8 suites, Conferencing, Health & fitness centre and Spa, merging artistry with comfort to create an ambiance that feels both inviting and distinctive."}, {"self_ref": "#/texts/19", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 2, "bbox": {"l": 200.7466, "t": 84.0854499999999, "r": 278.5164179000001, "b": 61.86106252455784, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 167]}], "orig": "Our dining options present an inventive mix of local and i