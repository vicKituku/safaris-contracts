": 5, "bbox": {"l": 70.584, "t": 164.8060122070312, "r": 761.314, "b": 139.1540122070312, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 150]}], "orig": "· To reserve and confirm room a 50% deposit for peak period and 30% for high and low season of the total amount of the invoice is required to be paid.", "text": "To reserve and confirm room a 50% deposit for peak period and 30% for high and low season of the total amount of the invoice is required to be paid.", "enumerated": false, "marker": "·"}, {"self_ref": "#/texts/40", "parent": {"$ref": "#/groups/6"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 5, "bbox": {"l": 70.584, "t": 130.4660122070312, "r": 353.02, "b": 119.70287408548427, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 56]}], "orig": "· Balance to be cleared 15 days prior to guest check in.", "text": "Balance to be cleared 15 days prior to guest check in.", "enumerated": false, "marker": "·"}, {"self_ref": "#/texts/41", "parent": {"$ref": "#/groups/6"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 5, "bbox": {"l": 70.584, "t": 111.02601220703121, "r": 579.17, "b": 100.26287408548427, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 112]}], "orig": "· Bookings not secured by the appropriate deposit will be released automatically and without prior notification.", "text": "Bookings not secured by the appropriate deposit will be released automatically and without prior notification.", "enumerated": false, "marker": "·"}, {"self_ref": "#/texts/42", "parent": {"$ref": "#/groups/6"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 6, "bbox": {"l": 71.304, "t": 547.2760122070312, "r": 325.3958400000002, "b": 536.5128740854842, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 50]}], "orig": "· We accept cheques 5 working days prior check in.", "text": "We accept cheques 5 working days prior check in.", "enumerated": false, "marker": "·"}, {"self_ref": "#/texts/43", "parent": {"$ref": "#/groups/6"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 6, "bbox": {"l": 70.584, "t": 532.3960122070312, "r": 765.3824799999996, "b": 493.4552922070312, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 377]}], "orig": "· In the event a cheque is returned by the bank as 'UNPAID' for any reason the agent shall replace the payment and additionally agree to pay the returned cheque fee thereof. The agent agrees to pay any and all costs, including legal fees, courts costs and any other expenses incurred by Mara Chui Resort in the collection of unpaid invoices, returned cheques or default payment", "text": "In the event a cheque is returned by the bank as 'UNPAID' for any reason the agent shall replace the payment and additionally agree to pay the returned cheque fee thereof. The agent agrees to pay any and all costs, including legal fees, courts costs and any other expenses incurred by Mara Chui Resort in the collection of unpaid invoices, returned cheques or default payment", "enumerated": false, "marker": "·"}, {"self_ref": "#/texts/44", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 6, "bbox": {"l": 75.624, "t": 479.55617220703124, "r": 269.53, "b": 466.0309431161221, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 19]}], "orig": "CHECK IN/ CHECK OUT", "text": "CHECK IN/ CHECK OUT", "level": 1}, {"self_ref": "#/texts/45", "parent": {"$ref": "#/groups/7"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 6, "bbox": {"l": 70.584, "t": 451.7271322070312, "r": 171.76999999999998, "b": 441.825045135208, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 18]}], "orig": "· Check in 1200hrs", "text": "Check in 1200hrs", "enumerated": false, "marker": "·"}, {"self_ref": "#/texts/46", "parent": {"$ref": "#/groups/7"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 6, "bbox": {"l": 70.584, "t": 435.64713220703123, "r": 463.44, "b": 425.745045135208, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 84]}], "orig": "· Check out before 1000hrs (Late check out is subject to accommodation availability)", "text": "Check out before 1000hrs (Late check out is subject to accommodation availability)", "enumerated": false, "marker": "·"}, {"self_ref": "#/texts/47", "parent": {"$ref": "#/groups/7"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 6, "bbox": {"l": 70.584, "t": 419.32713220703124, "r": 694.39, "b": 409.425045135208, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 141]}], "orig": "· Guest always responsible of his/her property by himself including the vehicle. Children are at all times to be supervised by their parents.", "text": "Guest always responsible of his/her property by himself including the vehicle. Children are at all times to be supervised by their parents.", "enumerated": false, "marker": "·"}, {"self_ref": "#/texts/48", "parent": {"$ref": "#/groups/7"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 6, "bbox": {"l": 70.584, "t": 403.2471322070312, "r": 497.78, "b": 393.34504513520795, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 94]}], "orig": "· Any damages to the hotel property by guest will be charged for accordingly to the situation.", "text": "Any damages to the hotel property by guest will be charged for accordingly to the situation.", "enumerated": false, "marker": "·"}, {"self_ref": "#/texts/49", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 6, "bbox": {"l": 75.624, "t": 306.4461722070312, "r": 396.29999999999995, "b": 292.9209431161221, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 31]}], "orig": "FORCE MAJEURE SUSPENSION CLAUSE", "text": "FORCE MAJEURE SUSPENSION CLAUSE", "level": 1}, {"self_ref": "#/texts/50", "parent": {"$ref": "#/body"}, "children": [], "content