": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 2, "bbox": {"l": 61.963, "t": 214.82699121093742, "r": 159.33899999999997, "b": 206.82699121093742, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 18]}], "orig": "PROOF OF RESIDENCY", "text": "PROOF OF RESIDENCY", "level": 1}, {"self_ref": "#/texts/32", "parent": {"$ref": "#/groups/3"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 2, "bbox": {"l": 61.963, "t": 206.47399121093736, "r": 528.5229999999992, "b": 179.84399121093747, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 331]}], "orig": "· Resident rates are applicable to residents of Kenya, Uganda, Tanzania, Rwanda and Burundi. Guests are required to provide their National ID (for Kenyan citizens) or passport displaying work permits or appropriate visas to prove resident status. Visitors without valid documentation will be required to pay the non-resident rates.", "text": "Resident rates are applicable to residents of Kenya, Uganda, Tanzania, Rwanda and Burundi. Guests are required to provide their National ID (for Kenyan citizens) or passport displaying work permits or appropriate visas to prove resident status. Visitors without valid documentation will be required to pay the non-resident rates.", "enumerated": false, "marker": "·"}, {"self_ref": "#/texts/33", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 2, "bbox": {"l": 61.963, "t": 168.2369912109375, "r": 259.41100000000006, "b": 160.2369912109375, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 36]}], "orig": "PROVISIONAL BOOKINGS & PAYMENT TERMS", "text": "PROVISIONAL BOOKINGS & PAYMENT TERMS", "level": 1}, {"self_ref": "#/texts/34", "parent": {"$ref": "#/groups/4"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 2, "bbox": {"l": 61.963, "t": 159.46999121093745, "r": 536.1069999999992, "b": 141.63899121093755,