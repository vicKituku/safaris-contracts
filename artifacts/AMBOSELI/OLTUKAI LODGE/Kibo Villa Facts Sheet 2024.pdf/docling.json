/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 1, "bbox": {"l": 29.832, "t": 275.8504746484375, "r": 274.65260300000006, "b": 263.55635009147545, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 26]}], "orig": "ABOUT- KIBO VILLA AMBOSELI", "text": "ABOUT- KIBO VILLA AMBOSELI", "level": 1}, {"self_ref": "#/texts/2", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 1, "bbox": {"l": 29.5537, "t": 235.61474464843752, "r": 90.35339809999999, "b": 224.9714997971364, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 8]}], "orig": "Location", "text": "Location", "level": 1}, {"self_ref": "#/texts/3", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 29.5537, "t": 220.0811146484375, "r": 309.9836999999999, "b": 168.8646277455099, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 220]}], "orig": "Kibo Villa is secluded in five acres of gardens, lawns and a little forest of indigenous tortilis acacia trees. Its tranquil atmosphere combines luxuriant comfort with the ethereal bush appeal of its rugged surroundings.", "text": "Kibo Villa is secluded in five acres of gardens, lawns and a little forest of indigenous tortilis acacia trees. Its tranquil atmosphere combines luxuriant comfort with the ethereal bush appeal of its rugged surroundings."}, {"self_ref": "#/texts/4", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 29.5537, "t": 164.0811146484375, "r": 313.0037, "b": 56.86462774550989, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 490]}], "orig": "Built in natural stone and elegant gum pole structures, Kibo Villa has three large master en suite bedrooms, a lounge, a fully facilitated kitchen, a barbeque area, and a dining area that stretches onto a large veranda. The master bedroom occupies the top floor, which opens onto a terrace where guest(s) can relax and admire the views of Mt. Kilimanjaro as well as the wildlife grazing on the plains directly ahead. The villa is accessed through its own private entrance and has a carport.", "text": "Built in natural stone and elegant gum pole structures, Kibo Villa has three large master en suite bedrooms, a lounge, a fully facilitated kitchen, a barbeque area, and a dining area that stretches onto a large veranda. The master bedroom occupies the top floor, which opens onto a terrace where guest(s) can relax and admire the views of Mt. Kilimanjaro as well as the wildlife grazing on the plains directly ahead. The villa is accessed through its own private entrance and has a carport."}, {"self_ref": "#/texts/5", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 2, "bbox": {"l": 17.9404, "t": 799.4186146484375, "r": 127.51480000000001, "b": 788.2294004727827, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 13]}], "orig": "ACCOMMODATION", "text": "ACCOMMODATION", "level": 1}, {"self_ref": "#/texts/6", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 2, "bbox": {"l": 17.9404, "t": 783.3896146484375, "r": 156.58039999999994, "b": 774.1731277455099, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 31]}], "orig": "Accommodation is all-inclusive.", "text": "Accommodation is all-inclusive."}, {"self_ref": "#/texts/7", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 2, "bbox": {"l": 17.9404, "t": 754.1296146484375, "r": 282.06039999999996, "b": 730.2831277455099, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 79]}], "orig": "Guests may also use the Ol Tukai Lodge facilities, which is in close proximity.", "text": "Guests may also use the Ol Tukai Lodge facilities, which is in close proximity."}, {"self_ref": "#/texts/8", "parent": {"$ref": "#/body"}, "children"